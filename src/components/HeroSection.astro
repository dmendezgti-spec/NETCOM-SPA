---
import { siteConfig } from '@/data/site';
---

<section class="relative overflow-hidden">
  <div class="absolute inset-x-0 top-0 -z-10 h-[38rem] bg-grid grid-glow opacity-25"></div>
  <div class="container-shell section-space pt-14 lg:pt-20">
    <div class="grid items-center gap-10 lg:grid-cols-[1.15fr,0.85fr]">
      <div class="space-y-8">
        <span class="eyebrow">{siteConfig.hero.badge}</span>
        <div class="space-y-6">
          <h1 class="text-balance font-display text-5xl font-bold leading-[1.05] text-white md:text-6xl xl:text-7xl">
            {siteConfig.hero.title}
          </h1>
          <p class="max-w-2xl text-lg leading-8 text-white/70">
            {siteConfig.hero.description}
          </p>
        </div>
        <div class="flex flex-col gap-4 sm:flex-row">
          <a href="/contacto" class="cta-primary">{siteConfig.hero.primaryCta}</a>
          <a href="/servicios" class="cta-secondary">{siteConfig.hero.secondaryCta}</a>
        </div>
        <div class="grid gap-4 sm:grid-cols-3">
          {siteConfig.stats.map((item) => (
            <div class="rounded-[1.5rem] border border-white/10 bg-white/[0.04] p-5">
              <div class="font-display text-2xl font-bold text-brand-200">{item.value}</div>
              <p class="mt-2 text-sm leading-6 text-white/62">{item.label}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="panel card-outline hero-highlight overflow-hidden p-7 md:p-9">
        <div class="grid gap-5">
          <div class="rounded-[1.75rem] border border-white/10 bg-ink-950/80 p-6">
            <div class="flex items-center justify-between gap-4">
              <div>
                <p class="text-xs uppercase tracking-[0.3em] text-white/45">Capacidades integradas</p>
                <h2 class="mt-3 font-display text-2xl font-bold text-white">Software, conectividad, seguridad e infraestructura</h2>
              </div>
              <span class="rounded-full border border-brand-300/20 bg-brand-400/10 px-3 py-1 text-xs font-semibold text-brand-100">Corporativo</span>
            </div>
          </div>
          <div class="grid gap-4 md:grid-cols-2">
            <div class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5">
              <p class="text-sm font-semibold text-white">Área TI</p>
              <p class="mt-2 text-sm leading-6 text-white/60">Software a medida, POS, soporte informático, mantención tecnológica, redes y conectividad.</p>
            </div>
            <div class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5">
              <p class="text-sm font-semibold text-white">Área de terreno</p>
              <p class="mt-2 text-sm leading-6 text-white/60">Cableado estructurado, telecom, CCTV, control de acceso, canalización y habilitaciones técnicas.</p>
            </div>
          </div>
          <div class="rounded-[1.75rem] border border-brand-400/20 bg-brand-400/10 p-6">
            <p class="text-sm leading-7 text-brand-50">
              NETCOM une estrategia digital y ejecución física para que una empresa no tenga que coordinar múltiples proveedores cuando el proyecto requiere software, infraestructura y trabajo en terreno.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>