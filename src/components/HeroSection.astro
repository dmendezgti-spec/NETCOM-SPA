---
import { siteConfig } from '@/data/site';

interface Props {
  variant?: 'a' | 'b';
}

const { variant = 'a' } = Astro.props;

const heroVariant =
  variant === 'b'
    ? {
        badge: 'Infraestructura + operación + tecnología',
        title: 'Ejecución técnica integral para empresas que necesitan operar sin detenerse.',
        description:
          'Desde software y conectividad hasta obras, mantención, canalización e instalaciones en terreno. NETCOM aborda el proyecto completo con estándar corporativo.',
        primaryCta: 'Solicitar visita técnica',
        secondaryCta: 'Explorar líneas de negocio',
      }
    : siteConfig.hero;
---

<section class="relative overflow-hidden">
  <div class="absolute inset-x-0 top-0 -z-10 h-[38rem] bg-grid grid-glow opacity-25"></div>
  <div class="container-shell section-space pt-14 lg:pt-20">
    <div class="grid items-center gap-10 lg:grid-cols-[1.15fr,0.85fr]">
      <div class="space-y-8">
        <span class="eyebrow">{heroVariant.badge}</span>
        <div class="space-y-6">
          <h1 class="heading-hero">
            {heroVariant.title}
          </h1>
          <p class="copy-md max-w-2xl">
            {heroVariant.description}
          </p>
        </div>
        <div class="flex flex-col gap-4 sm:flex-row">
          <a href="/contacto" class="cta-primary">{heroVariant.primaryCta}</a>
          <a href="/servicios" class="cta-secondary">{heroVariant.secondaryCta}</a>
        </div>
        <div class="grid gap-3 sm:grid-cols-3">
          {siteConfig.stats.map((item) => (
            <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-5">
              <div class="text-xs font-bold uppercase tracking-[0.2em] text-warning">{item.value}</div>
              <p class="mt-2 text-sm leading-6 text-white/60">{item.label}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="panel card-outline hero-highlight overflow-hidden p-0">
        <!-- Header -->
        <div class="flex items-center justify-between gap-4 border-b border-white/10 px-6 py-4">
          <div class="flex items-center gap-2.5">
            <span class="h-2 w-2 rounded-full bg-emerald-400 shadow-[0_0_8px_rgba(52,211,153,0.55)]"></span>
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-white/50">Áreas de trabajo</p>
          </div>
          <span class="rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-xs text-white/35">8 servicios activos</span>
        </div>
        <!-- Visual grid 2x2 -->
        <div class="grid grid-cols-2 divide-x divide-y divide-white/[0.07] border-b border-white/10">
          <div class="group relative overflow-hidden">
            <img src="/images/service-software.jpg" alt="Software y plataformas digitales" class="h-36 w-full object-cover transition duration-500 group-hover:scale-105" loading="eager" />
            <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-ink-950/90 to-transparent px-4 py-3">
              <span class="text-[0.62rem] font-bold uppercase tracking-[0.2em] text-brand-200">Software · Redes</span>
            </div>
          </div>
          <div class="group relative overflow-hidden">
            <img src="/images/service-cctv.jpg" alt="CCTV y seguridad" class="h-36 w-full object-cover transition duration-500 group-hover:scale-105" loading="eager" />
            <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-ink-950/90 to-transparent px-4 py-3">
              <span class="text-[0.62rem] font-bold uppercase tracking-[0.2em] text-brand-200">CCTV · Seguridad</span>
            </div>
          </div>
          <div class="group relative overflow-hidden">
            <img src="/images/service-network.jpg" alt="Redes y telecomunicaciones" class="h-36 w-full object-cover transition duration-500 group-hover:scale-105" loading="lazy" />
            <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-ink-950/90 to-transparent px-4 py-3">
              <span class="text-[0.62rem] font-bold uppercase tracking-[0.2em] text-warning">Telecomunicaciones</span>
            </div>
          </div>
          <div class="group relative overflow-hidden">
            <img src="/images/service-construction.jpg" alt="Obras e instalaciones técnicas" class="h-36 w-full object-cover transition duration-500 group-hover:scale-105" loading="lazy" />
            <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-ink-950/90 to-transparent px-4 py-3">
              <span class="text-[0.62rem] font-bold uppercase tracking-[0.2em] text-warning">Obras · Instalaciones</span>
            </div>
          </div>
        </div>
        <!-- Footer -->
        <div class="px-6 py-4">
          <p class="text-sm leading-6 text-white/45">Un solo equipo técnico. Ambas líneas coordinadas internamente.</p>
        </div>
      </div>
    </div>
  </div>
</section>