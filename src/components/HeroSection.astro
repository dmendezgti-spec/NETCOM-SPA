---
import { siteConfig } from '@/data/site';

interface Props {
  variant?: 'a' | 'b';
}

const { variant = 'a' } = Astro.props;

const heroVariant =
  variant === 'b'
    ? {
        badge: 'Infraestructura + operación + tecnología',
        title: 'Ejecución técnica integral para empresas que necesitan operar sin detenerse.',
        description:
          'Desde software y conectividad hasta obras, mantención, canalización e instalaciones en terreno. NETCOM aborda el proyecto completo con estándar corporativo.',
        primaryCta: 'Solicitar visita técnica',
        secondaryCta: 'Explorar líneas de negocio',
      }
    : siteConfig.hero;
---

<section class="relative overflow-hidden">
  <div class="absolute inset-x-0 top-0 -z-10 h-[38rem] bg-grid grid-glow opacity-25"></div>
  <div class="container-shell section-space pt-14 lg:pt-20">
    <div class="grid items-center gap-10 lg:grid-cols-[1.15fr,0.85fr]">
      <div class="space-y-8">
        <span class="eyebrow">{heroVariant.badge}</span>
        <div class="space-y-6">
          <h1 class="text-balance font-display text-5xl font-bold leading-[1.05] text-white md:text-6xl xl:text-7xl">
            {heroVariant.title}
          </h1>
          <p class="max-w-2xl text-lg leading-8 text-white/70">
            {heroVariant.description}
          </p>
        </div>
        <div class="flex flex-col gap-4 sm:flex-row">
          <a href="/contacto" class="cta-primary">{heroVariant.primaryCta}</a>
          <a href="/servicios" class="cta-secondary">{heroVariant.secondaryCta}</a>
        </div>
        <p class="max-w-2xl rounded-2xl border border-accent/30 bg-accent/10 px-4 py-3 text-sm leading-7 text-accent">
          Tecnología que se implementa en terreno: desde diseño de software y redes hasta obras menores, canalización y habilitaciones técnicas para operación real.
        </p>
        <div class="grid gap-4 sm:grid-cols-3">
          {siteConfig.stats.map((item) => (
            <div class="rounded-[1.5rem] border border-white/10 bg-white/[0.04] p-5">
              <div class="font-display text-2xl font-bold text-brand-200">{item.value}</div>
              <p class="mt-2 text-sm leading-6 text-white/62">{item.label}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="panel card-outline hero-highlight overflow-hidden p-7 md:p-9">
        <div class="grid gap-5">
          <div class="rounded-[1.75rem] border border-white/10 bg-ink-950/80 p-6">
            <div class="flex items-center justify-between gap-4">
              <div>
                <p class="text-xs uppercase tracking-[0.3em] text-white/45">Capacidades integradas</p>
                <h2 class="mt-3 font-display text-2xl font-bold text-white">Software, conectividad, seguridad e infraestructura</h2>
              </div>
              <span class="rounded-full border border-brand-300/20 bg-brand-400/10 px-3 py-1 text-xs font-semibold text-brand-100">Corporativo</span>
            </div>
          </div>
          <div class="grid gap-4 md:grid-cols-2">
            <div class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5">
              <p class="text-sm font-semibold text-white">Área TI</p>
              <p class="mt-2 text-sm leading-6 text-white/60">Software a medida, POS, soporte informático, redes, conectividad y telecomunicaciones.</p>
            </div>
            <div class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5">
              <p class="text-sm font-semibold text-white">Área obras e infraestructura</p>
              <p class="mt-2 text-sm leading-6 text-white/60">Obras menores, mantención, instalaciones técnicas, canalización, habilitaciones y ejecución en terreno.</p>
            </div>
          </div>
          <div class="rounded-[1.75rem] border border-brand-400/20 bg-brand-400/10 p-6">
            <p class="text-sm leading-7 text-brand-50">
              NETCOM une estrategia digital y ejecución física para que cada proyecto tenga continuidad: una empresa, una planificación, una ejecución técnica y una operación que funciona.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>