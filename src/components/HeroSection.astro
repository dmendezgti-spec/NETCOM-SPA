---
import { siteConfig } from '@/data/site';

interface Props {
  variant?: 'a' | 'b';
}

const { variant = 'a' } = Astro.props;

const heroVariant =
  variant === 'b'
    ? {
        badge: 'Infraestructura + operación + tecnología',
        title: 'Ejecución técnica integral para empresas que necesitan operar sin detenerse.',
        description:
          'Desde software y conectividad hasta obras, mantención, canalización e instalaciones en terreno. NETCOM aborda el proyecto completo con estándar corporativo.',
        primaryCta: 'Solicitar visita técnica',
        secondaryCta: 'Explorar líneas de negocio',
      }
    : siteConfig.hero;
---

<section class="relative overflow-hidden">
  <div class="absolute inset-x-0 top-0 -z-10 h-[38rem] bg-grid grid-glow opacity-25"></div>
  <div class="container-shell section-space pt-14 lg:pt-20">
    <div class="grid items-center gap-10 lg:grid-cols-[1.15fr,0.85fr]">
      <div class="space-y-8">
        <span class="eyebrow">{heroVariant.badge}</span>
        <div class="space-y-6">
          <h1 class="heading-hero">
            {heroVariant.title}
          </h1>
          <p class="copy-md max-w-2xl">
            {heroVariant.description}
          </p>
        </div>
        <div class="flex flex-col gap-4 sm:flex-row">
          <a href="/contacto" class="cta-primary">{heroVariant.primaryCta}</a>
          <a href="/servicios" class="cta-secondary">{heroVariant.secondaryCta}</a>
        </div>
        <p class="max-w-2xl rounded-2xl border border-brand-300/20 bg-brand-400/10 px-4 py-3 text-sm leading-7 text-brand-100">
          Tecnología que se implementa en terreno: desde diseño de software y redes hasta obras menores, canalización y habilitaciones técnicas para operación real.
        </p>
        <div class="grid gap-4 sm:grid-cols-3">
          {siteConfig.stats.map((item) => (
            <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-5">
              <div class="font-display text-xl font-bold text-brand-200 md:text-2xl">{item.value}</div>
              <p class="mt-2 text-sm leading-6 text-white/62">{item.label}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="panel card-outline hero-highlight overflow-hidden p-0">
        <!-- Header bar -->
        <div class="flex items-center justify-between gap-4 border-b border-white/10 px-7 py-5">
          <p class="text-xs font-semibold uppercase tracking-[0.26em] text-white/45">Capacidades integradas</p>
          <span class="rounded-full border border-brand-300/20 bg-brand-400/10 px-3 py-1.5 text-xs font-semibold text-brand-200">Empresa 360°</span>
        </div>
        <!-- Áreas grid -->
        <div class="grid divide-y divide-white/10 border-b border-white/10 sm:grid-cols-2 sm:divide-x sm:divide-y-0">
          <div class="p-6">
            <p class="mb-2 text-[0.65rem] font-bold uppercase tracking-[0.26em] text-warning">Área TI</p>
            <p class="text-sm font-medium leading-6 text-white/85">Software, POS, redes, soporte y telecomunicaciones.</p>
          </div>
          <div class="p-6">
            <p class="mb-2 text-[0.65rem] font-bold uppercase tracking-[0.26em] text-warning">Área Terreno</p>
            <p class="text-sm font-medium leading-6 text-white/85">Obras, habilitaciones, canalización e instalaciones técnicas.</p>
          </div>
        </div>
        <!-- Statement -->
        <div class="px-7 py-6">
          <p class="copy-sm">Una sola contraparte técnica para coordinar software, redes e infraestructura con criterio operacional.</p>
        </div>
      </div>
    </div>
  </div>
</section>