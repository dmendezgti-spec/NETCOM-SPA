---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<article class="rounded-2xl border border-white/10 bg-white/[0.04] p-6 transition hover:bg-white/[0.06]">
  <h3 class="heading-card">{title}</h3>
  <p class="copy-sm mt-3">{description}</p>
</article>