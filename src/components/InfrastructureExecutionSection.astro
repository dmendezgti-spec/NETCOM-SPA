---
import SectionHeading from '@/components/SectionHeading.astro';
import { infrastructureExecutionPillars, integrationStatement } from '@/data/site';
---

<section class="section-space pt-0">
  <div class="container-shell space-y-10">
    <SectionHeading
      badge="Infraestructura, Mantención y Obras"
      title="Capacidad real de ejecución en terreno para proyectos técnicos y comerciales"
      description="Esta línea de negocio tiene protagonismo propio: habilitamos espacios, ejecutamos instalaciones, mantenemos infraestructura y acompañamos la operación diaria de cada cliente."
    />

    <div class="panel card-outline p-7 lg:p-10">
      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
        {infrastructureExecutionPillars.map((pillar, index) => (
          <article class="rounded-2xl border border-white/10 bg-white/[0.04] p-5">
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-brand-400/15 text-xs font-bold text-brand-300">
              {`0${index + 1}`}
            </span>
            <h3 class="heading-card mt-4">{pillar.title}</h3>
            <p class="mt-3 text-sm leading-7 text-white/62">{pillar.description}</p>
          </article>
        ))}
      </div>

      <div class="mt-8 rounded-2xl border border-brand-300/20 bg-brand-400/10 p-6">
        <p class="text-sm leading-7 text-brand-50">{integrationStatement}</p>
        <div class="mt-5 flex flex-wrap gap-3">
          <a href="/servicios#obras-menores" class="cta-primary">Ver línea de obras y mantención</a>
          <a href="/contacto" class="cta-secondary">Solicitar cotización de terreno</a>
        </div>
      </div>
    </div>
  </div>
</section>