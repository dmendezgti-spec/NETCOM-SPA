---
interface Props {
  badge: string;
  title: string;
  description: string;
}

const { badge, title, description } = Astro.props;
---

<section class="relative overflow-hidden border-b border-white/10">
  <div class="container-shell py-20 lg:py-24">
    <div class="max-w-4xl space-y-6">
      <span class="eyebrow">{badge}</span>
      <h1 class="text-balance font-display text-3xl font-bold leading-tight text-white md:text-5xl">{title}</h1>
      <p class="max-w-3xl text-base leading-8 text-white/68 md:text-lg">{description}</p>
    </div>
  </div>
</section>