---
interface Props {
  title: string;
  category: string;
  summary: string;
}

const { title, category, summary } = Astro.props;
---

<article class="panel h-full p-6">
  <div class="flex h-full flex-col gap-4">
    <span class="inline-flex w-fit rounded-full border border-brand-300/20 bg-brand-400/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.22em] text-brand-100">
      {category}
    </span>
    <h3 class="heading-card break-words hyphens-auto">{title}</h3>
    <p class="copy-sm mt-auto break-words">{summary}</p>
  </div>
</article>