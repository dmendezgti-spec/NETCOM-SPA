---
interface Props {
  badge?: string;
  title: string;
  description: string;
  centered?: boolean;
}

const { badge, title, description, centered = false } = Astro.props;
---

<div class:list={['space-y-5', centered && 'mx-auto max-w-3xl text-center']}>
  {badge && <span class="eyebrow">{badge}</span>}
  <div class="space-y-3">
    <h2 class="text-balance font-display text-3xl font-bold leading-tight text-white md:text-4xl">{title}</h2>
    <p class="max-w-3xl text-base leading-8 text-white/68">{description}</p>
  </div>
</div>