---
interface Props {
  badge?: string;
  title: string;
  description: string;
  centered?: boolean;
}

const { badge, title, description, centered = false } = Astro.props;
---

<div class:list={['space-y-5', centered && 'mx-auto max-w-3xl text-center']}>
  {badge && <span class="eyebrow">{badge}</span>}
  <div class="space-y-3">
    <h2 class="heading-section">{title}</h2>
    <p class="copy-md max-w-3xl">{description}</p>
  </div>
</div>