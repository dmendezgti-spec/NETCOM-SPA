---
interface Props {
  title: string;
  short: string;
  href?: string;
  accent?: boolean;
}

const { title, short, href = '/servicios', accent = false } = Astro.props;
---

<article class:list={[
  'group relative flex h-full flex-col gap-5 rounded-2xl border p-6 transition duration-200',
  accent
    ? 'border-warning/20 bg-warning/[0.04] hover:border-warning/35 hover:bg-warning/[0.07]'
    : 'border-white/10 bg-white/[0.04] hover:border-brand-300/25 hover:bg-white/[0.07]',
]}>
  <div class="flex-1 space-y-3">
    <h3 class="heading-card">{title}</h3>
    <p class="copy-sm">{short}</p>
  </div>
  <a
    href={href}
    class:list={[
      'inline-flex items-center gap-1.5 text-sm font-semibold transition',
      accent ? 'text-warning/80 hover:text-warning' : 'text-brand-200/80 hover:text-brand-100',
    ]}
  >
    Más información
    <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">→</span>
  </a>
</article>