---
import { navigationItems } from '@/data/navigation';
import { serviceLines, siteConfig } from '@/data/site';
---

<footer class="border-t border-white/10 bg-black/20">
  <div class="container-shell grid gap-12 py-14 lg:grid-cols-[1.3fr,0.9fr,0.9fr]">
    <div class="space-y-5">
      <div class="flex items-center gap-3">
        <img src="/brand/netcom-mark.svg" alt="NETCOM" class="h-10 w-10 sm:hidden" loading="lazy" />
        <img src="/brand/netcom-logo-option-a.svg" alt="NETCOM Servicios Integrales SpA" class="hidden h-12 w-auto sm:block" loading="lazy" />
      </div>
      <div>
        <h2 class="font-display text-2xl font-bold text-white">Tecnología corporativa con capacidad real de ejecución.</h2>
        <p class="mt-3 max-w-xl text-sm leading-7 text-white/68">
          Software, redes, telecomunicaciones, seguridad e infraestructura técnica bajo una misma contraparte para proyectos que exigen orden, continuidad y criterio de terreno.
        </p>
      </div>
      <div class="flex flex-wrap gap-3 text-sm text-white/70">
        <a href={`mailto:${siteConfig.email}`} class="rounded-full border border-white/10 px-4 py-2 transition hover:border-brand-300/40 hover:text-white">{siteConfig.email}</a>
        <a href={`tel:${siteConfig.phone}`} class="rounded-full border border-white/10 px-4 py-2 transition hover:border-brand-300/40 hover:text-white">{siteConfig.phone}</a>
      </div>
    </div>

    <div>
      <h3 class="font-display text-sm font-bold uppercase tracking-[0.24em] text-white/55">Navegación</h3>
      <ul class="mt-5 space-y-3 text-sm text-white/68">
        {navigationItems.map((item) => (
          <li><a href={item.href} class="transition hover:text-white">{item.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h3 class="font-display text-sm font-bold uppercase tracking-[0.24em] text-white/55">Líneas de negocio</h3>
      <ul class="mt-5 space-y-3 text-sm text-white/68">
        {serviceLines.slice(0, 8).map((service) => (
          <li><a href={`/servicios#${service.slug}`} class="transition hover:text-white">{service.title}</a></li>
        ))}
      </ul>
    </div>
  </div>
  <div class="border-t border-white/10">
    <div class="container-shell flex flex-col gap-3 py-5 text-xs text-white/45 md:flex-row md:items-center md:justify-between">
      <p>© {new Date().getFullYear()} {siteConfig.legalName}. Todos los derechos reservados.</p>
      <p>Sitio preparado para SEO, Cloudflare Pages y crecimiento comercial por servicio.</p>
    </div>
  </div>
</footer>