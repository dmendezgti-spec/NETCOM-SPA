---
import { navigationItems } from '@/data/navigation';
import { siteConfig } from '@/data/site';

const pathname = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-ink-950/85 backdrop-blur-xl">
  <div class="container-shell flex items-center justify-between gap-6 py-4">
    <a href="/" class="flex items-center gap-3 text-white" aria-label="Ir al inicio de NETCOM">
      <span class="flex h-11 w-11 items-center justify-center rounded-2xl border border-brand-300/20 bg-brand-400/10 text-lg font-bold text-brand-200">N</span>
      <span>
        <span class="block font-display text-sm font-bold tracking-[0.18em] text-white">NETCOM</span>
        <span class="block text-xs text-white/50">Servicios Integrales SpA</span>
      </span>
    </a>

    <nav class="hidden items-center gap-6 lg:flex" aria-label="Principal">
      {navigationItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'text-sm font-medium transition',
            pathname === item.href ? 'text-brand-200' : 'text-white/68 hover:text-white',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="hidden items-center gap-3 lg:flex">
      <a href={`tel:${siteConfig.phone}`} class="text-sm text-white/70 transition hover:text-white">{siteConfig.phone}</a>
      <a href="/contacto" class="cta-primary">Cotizar proyecto</a>
    </div>

    <button
      type="button"
      class="inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-white/10 bg-white/5 text-white lg:hidden"
      aria-expanded="false"
      aria-controls="mobile-menu"
      data-menu-toggle
    >
      <span class="sr-only">Abrir menú</span>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M4 7H20" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        <path d="M4 12H20" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        <path d="M4 17H20" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="container-shell hidden pb-5 lg:hidden" data-mobile-menu>
    <div class="panel space-y-2 p-4">
      {navigationItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'block rounded-2xl px-4 py-3 text-sm font-medium transition',
            pathname === item.href ? 'bg-brand-400/10 text-brand-200' : 'text-white/75 hover:bg-white/5 hover:text-white',
          ]}
        >
          {item.label}
        </a>
      ))}
      <a href="/contacto" class="cta-primary mt-3 w-full">Solicitar cotización</a>
    </div>
  </div>
</header>

<script>
  const toggle = document.querySelector('[data-menu-toggle]');
  const menu = document.querySelector('[data-mobile-menu]');

  if (toggle instanceof HTMLButtonElement && menu instanceof HTMLElement) {
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      menu.classList.toggle('hidden');
    });
  }
</script>