  href={whatsappUrl}
  class="fixed bottom-5 right-5 z-40 inline-flex items-center gap-3 rounded-full border border-warning/30 bg-warning px-5 py-3 text-sm font-semibold text-white shadow-glow transition hover:bg-warning/85 hover:scale-[1.02]"
  target="_blank"
  rel="noreferrer"
  aria-label="Contactar por WhatsApp"
>
  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <path d="M19.05 4.91A9.82 9.82 0 0012.03 2C6.57 2 2.13 6.43 2.13 11.89c0 1.75.46 3.45 1.33 4.95L2 22l5.31-1.39a9.84 9.84 0 004.72 1.2h.01c5.46 0 9.9-4.43 9.9-9.89a9.8 9.8 0 00-2.89-7.01z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M16.84 14.54c-.26-.13-1.53-.75-1.77-.83-.24-.09-.41-.13-.59.13-.17.26-.67.83-.82 1-.15.18-.3.2-.56.07-.26-.13-1.08-.4-2.07-1.29-.77-.68-1.3-1.52-1.45-1.78-.15-.26-.02-.4.11-.53.12-.12.26-.3.39-.45.13-.15.17-.26.26-.44.09-.18.04-.33-.02-.46-.07-.13-.59-1.42-.81-1.95-.21-.5-.43-.43-.59-.44h-.5c-.18 0-.46.07-.7.33-.24.26-.92.9-.92 2.2 0 1.3.94 2.56 1.07 2.73.13.18 1.85 2.83 4.47 3.97.62.27 1.11.44 1.49.56.63.2 1.21.17 1.67.1.51-.08 1.53-.62 1.75-1.22.22-.6.22-1.12.15-1.22-.06-.1-.24-.16-.5-.29z" fill="currentColor"/>
