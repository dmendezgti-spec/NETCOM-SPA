---
import ContactForm from '@/components/ContactForm.astro';
import FAQAccordion from '@/components/FAQAccordion.astro';
import HeroSection from '@/components/HeroSection.astro';
import IndustryCard from '@/components/IndustryCard.astro';
import InfrastructureExecutionSection from '@/components/InfrastructureExecutionSection.astro';
import OperationVisualGallery from '@/components/OperationVisualGallery.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { featuredProjects, industries, serviceLines } from '@/data/site';

const technologyServices = serviceLines.filter((service) =>
  ['desarrollo-software', 'software-ventas-pos', 'redes-conectividad', 'telecomunicaciones', 'cctv-seguridad', 'soporte-informatico'].includes(service.slug),
);

const infrastructureServices = serviceLines.filter((service) =>
  ['obras-menores', 'construccion-habilitaciones'].includes(service.slug),
);

const heroVariant = Astro.url.searchParams.get('hero') === 'b' ? 'b' : 'a';
---

<BaseLayout>
  <HeroSection variant={heroVariant} />

  <InfrastructureExecutionSection />

  <OperationVisualGallery />

  <section class="section-space">
    <div class="container-shell space-y-12">
      <SectionHeading
        badge="Servicios principales"
        title="Dos líneas de negocio con el mismo peso comercial: tecnología e infraestructura"
        description="NETCOM responde proyectos completos combinando software, redes y telecomunicaciones con obras, mantención, instalaciones técnicas y ejecución en terreno."
      />

      <div class="space-y-6">
        <div class="flex items-center justify-between gap-4">
          <h3 class="font-display text-2xl font-bold text-white">Línea TI y conectividad</h3>
          <a href="/servicios" class="text-sm font-semibold text-brand-200 hover:text-accent">Ver todo el portafolio →</a>
        </div>
        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {technologyServices.map((service) => (
            <ServiceCard title={service.title} short={service.short} href={`/servicios#${service.slug}`} />
          ))}
        </div>
      </div>

      <div class="space-y-6">
        <div class="flex items-center justify-between gap-4">
          <h3 class="font-display text-2xl font-bold text-white">Línea infraestructura, mantención y obras</h3>
          <a href="/contacto" class="text-sm font-semibold text-brand-200 hover:text-accent">Cotizar ejecución en terreno →</a>
        </div>
        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-2">
          {infrastructureServices.map((service) => (
            <ServiceCard title={service.title} short={service.short} href={`/servicios#${service.slug}`} />
          ))}
        </div>
      </div>

      <div class="rounded-[1.75rem] border border-white/10 bg-white/[0.03] p-6 text-sm leading-7 text-white/70">
        NETCOM no opera con la lógica de proveedor parcial. Se diseña e implementa con visión integral para que una empresa no tenga que separar TI, redes, CCTV, obras e infraestructura entre múltiples contratistas.
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="container-shell">
      <div class="panel card-outline grid gap-8 p-8 lg:grid-cols-[1fr,1.1fr] lg:p-10">
        <div>
          <span class="eyebrow">Por qué NETCOM</span>
          <h2 class="mt-5 text-balance font-display text-3xl font-bold text-white md:text-4xl">
            Una sola contraparte para coordinar tecnología, operación e infraestructura técnica.
          </h2>
        </div>
        <div class="grid gap-4 md:grid-cols-2">
          <div class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5">
            <h3 class="font-display text-xl font-bold text-white">Continuidad operativa</h3>
            <p class="mt-3 text-sm leading-7 text-white/62">Diseño, instalación, mantención y soporte para reducir interrupciones en la operación comercial y técnica.</p>
          </div>
          <div class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5">
            <h3 class="font-display text-xl font-bold text-white">Capacidad de terreno</h3>
            <p class="mt-3 text-sm leading-7 text-white/62">Ejecución en obra, canalización, habilitación y montajes técnicos con estándar corporativo.</p>
          </div>
          <div class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5">
            <h3 class="font-display text-xl font-bold text-white">Criterio técnico comercial</h3>
            <p class="mt-3 text-sm leading-7 text-white/62">Soluciones aterrizadas para pymes, retail, oficinas y operaciones que requieren resultados medibles.</p>
          </div>
          <div class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5">
            <h3 class="font-display text-xl font-bold text-white">Base escalable</h3>
            <p class="mt-3 text-sm leading-7 text-white/62">Estructura preparada para crecimiento por sucursales, nuevas áreas y continuidad de servicio en el tiempo.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-space border-y border-white/10 bg-white/[0.02]">
    <div class="container-shell space-y-12">
      <SectionHeading
        badge="Soluciones por negocio"
        title="Servicios aterrizados a operaciones reales"
        description="El sitio queda preparado para crecer hacia páginas y landing pages por línea de negocio, pero desde ya comunica con claridad dónde NETCOM agrega valor según tipo de cliente."
      />
      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
        {industries.map((industry) => (
          <IndustryCard title={industry.title} description={industry.description} />
        ))}
      </div>
      <div class="flex flex-wrap gap-4">
        <a href="/soluciones" class="cta-primary">Explorar soluciones</a>
        <a href="/contacto" class="cta-secondary">Cotizar habilitación e instalación</a>
      </div>
    </div>
  </section>

  <section class="section-space">
    <div class="container-shell grid gap-12 lg:grid-cols-[0.95fr,1.05fr]">
      <div class="space-y-6">
        <SectionHeading
          badge="Experiencia preparada"
          title="Estructura lista para mostrar proyectos destacados y crecimiento futuro del portafolio"
          description="Aunque el sitio parte con una base corporativa, la arquitectura ya considera fichas resumidas, categorías y futura expansión a casos de éxito por servicio o industria."
        />
        <a href="/proyectos" class="cta-secondary">Ver estructura de proyectos</a>
      </div>
      <div class="grid gap-6 md:grid-cols-3">
        {featuredProjects.map((project) => (
          <ProjectCard title={project.title} category={project.category} summary={project.summary} />
        ))}
      </div>
    </div>
  </section>

  <section class="section-space border-y border-white/10 bg-white/[0.02]">
    <div class="container-shell grid gap-12 lg:grid-cols-[0.95fr,1.05fr]">
      <div class="space-y-6">
        <SectionHeading
          badge="Preguntas frecuentes"
          title="Respuestas claras para acelerar la decisión comercial"
          description="Sección pensada para reducir fricción, reforzar confianza y abrir futuras oportunidades de posicionamiento orgánico con contenido de intención comercial."
        />
      </div>
      <FAQAccordion />
    </div>
  </section>

  <section class="section-space">
    <div class="container-shell grid gap-10 lg:grid-cols-[0.8fr,1.2fr]">
      <div class="space-y-6">
        <SectionHeading
          badge="Cotización"
          title="Conversemos tu proyecto técnico, comercial u obra en terreno"
          description="Desde software y conectividad hasta canalización, mantención e instalaciones técnicas: la captación está preparada para proyectos integrales y solicitudes de cotización por servicio."
        />
        <div class="rounded-[1.75rem] border border-brand-300/20 bg-brand-400/10 p-6 text-sm leading-7 text-brand-50">
          Cada CTA del sitio conduce a un flujo de contacto consistente para clientes que buscan desarrollo, soporte, habilitación técnica o ejecución de obras menores.
        </div>
      </div>
      <ContactForm compact />
    </div>
  </section>
</BaseLayout>