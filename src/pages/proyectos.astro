---
import PageHero from '@/components/PageHero.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { featuredProjects, projectCategories } from '@/data/site';
---

<BaseLayout
  title="Proyectos y experiencia | NETCOM Servicios Integrales SpA"
  description="Proyectos destacados y experiencia de NETCOM en software, redes, seguridad e infraestructura técnica para empresas en Chile."
>
  <PageHero
    badge="Proyectos y experiencia"
    title="Experiencia aplicada en proyectos de tecnología e infraestructura"
    description="Mostramos trabajos ejecutados en entornos comerciales y operativos donde la continuidad del negocio exige soluciones técnicas bien implementadas."
  />

  <section class="section-space">
    <div class="container-shell space-y-10">
      <SectionHeading
        badge="Categorías"
        title="Casos organizados por tipo de solución"
        description="Software, conectividad, seguridad e infraestructura técnica con resultados enfocados en operación, control y continuidad."
      />
      <div class="flex flex-wrap gap-3">
        {projectCategories.map((category) => (
          <span class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-white/70">{category}</span>
        ))}
      </div>
      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {featuredProjects.map((project) => (
          <ProjectCard title={project.title} category={project.category} summary={project.summary} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>