---
import PageHero from '@/components/PageHero.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { serviceLines } from '@/data/site';

const technologyServices = serviceLines.filter((service) =>
  ['desarrollo-software', 'software-ventas-pos', 'redes-conectividad', 'telecomunicaciones', 'cctv-seguridad', 'soporte-informatico'].includes(service.slug),
);

const infrastructureServices = serviceLines.filter((service) =>
  ['obras-menores', 'construccion-habilitaciones'].includes(service.slug),
);

const serviceVisualBySlug: Record<string, string> = {
  'desarrollo-software': '/images/service-software.jpg',
  'software-ventas-pos': '/images/service-support.jpg',
  'redes-conectividad': '/images/service-network.jpg',
  telecomunicaciones: '/images/service-network.jpg',
  'cctv-seguridad': '/images/service-cctv.jpg',
  'soporte-informatico': '/images/service-support.jpg',
  'obras-menores': '/images/service-construction.jpg',
  'construccion-habilitaciones': '/images/service-construction.jpg',
};
---

<BaseLayout
  title="Servicios | NETCOM Servicios Integrales SpA"
  description="Servicios corporativos de software, POS, redes, telecomunicaciones, CCTV, soporte TI, obras menores y habilitaciones técnicas para empresas en Chile."
>
  <PageHero
    badge="Servicios"
    title="Portafolio integral: tecnología, soporte operativo y ejecución técnica en terreno"
    description="NETCOM estructura su oferta en dos líneas de negocio con igual peso: servicios TI y conectividad, junto a infraestructura, mantención y obras menores para habilitar operación real."
  />

  <section class="section-space">
    <div class="container-shell space-y-16">
      <SectionHeading
        badge="Líneas principales"
        title="Servicios organizados por foco de negocio para facilitar cotización y ejecución"
        description="Contenido simplificado para comparar rápido, entender valor y solicitar cotización sin fricción."
      />

      <article id="infraestructura-ejecucion-terreno" class="panel scroll-mt-28 border border-accent/20 bg-accent/10 p-8 lg:p-10">
        <div class="grid gap-7 lg:grid-cols-[1fr,1fr]">
          <div class="space-y-4">
            <span class="eyebrow">Infraestructura y Ejecución en Terreno</span>
            <h2 class="heading-section">Obras, mantención e instalaciones técnicas con estándar corporativo</h2>
            <p class="text-sm leading-7 text-white/80">
              Además de la capa TI, NETCOM ejecuta habilitaciones, canalizaciones, instalaciones y mantención de infraestructura para proyectos tecnológicos y comerciales en terreno.
            </p>
            <div class="grid gap-3 sm:grid-cols-2">
              <img src="/images/service-construction.jpg" alt="Obras y habilitaciones técnicas" class="h-28 w-full rounded-2xl object-cover" loading="lazy" />
              <img src="/images/service-network.jpg" alt="Infraestructura para redes y telecomunicaciones" class="h-28 w-full rounded-2xl object-cover" loading="lazy" />
            </div>
          </div>
            <div class="grid gap-3 sm:grid-cols-2">
              <div class="rounded-2xl border border-white/15 bg-white/10 p-4 text-sm leading-6 text-white/80">Habilitaciones técnicas para oficinas, locales y bodegas.</div>
              <div class="rounded-2xl border border-white/15 bg-white/10 p-4 text-sm leading-6 text-white/80">Canalización y adecuaciones para redes, CCTV y control de acceso.</div>
              <div class="rounded-2xl border border-white/15 bg-white/10 p-4 text-sm leading-6 text-white/80">Mantención preventiva y correctiva para continuidad operativa.</div>
              <div class="rounded-2xl border border-white/15 bg-white/10 p-4 text-sm leading-6 text-white/80">Ejecución de obras menores y soporte operativo en terreno.</div>
          </div>
        </div>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/contacto" class="cta-primary">Cotizar obras e instalaciones</a>
          <a href="#obras-menores" class="cta-secondary">Ver servicios de infraestructura</a>
        </div>
      </article>

      <div class="space-y-8">
        <h2 class="heading-section">Línea TI, software y conectividad</h2>
        <div class="space-y-8">
          {technologyServices.map((service) => (
            <article id={service.slug} class="panel scroll-mt-28 p-8 lg:p-10">
              <div class="grid gap-8 lg:grid-cols-[0.8fr,1.2fr]">
                <div class="space-y-4">
                  <span class="eyebrow">{service.title}</span>
                  <h3 class="heading-card text-balance">{service.short}</h3>
                  <p class="copy-sm">{service.description}</p>
                  <img src={serviceVisualBySlug[service.slug]} alt={service.title} class="h-40 w-full rounded-xl object-cover" loading="lazy" />
                  <a href="/contacto" class="cta-primary">Solicitar evaluación</a>
                </div>
                <div class="grid gap-5 md:grid-cols-2">
                  <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-5">
                    <h4 class="font-display text-sm font-bold uppercase tracking-[0.16em] text-white/55">Problemas que resuelve</h4>
                    <ul class="mt-4 space-y-3 text-sm leading-7 text-white/62">
                      {service.problems.slice(0, 2).map((problem) => (
                        <li>• {problem}</li>
                      ))}
                    </ul>
                  </div>
                  <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-5">
                    <h4 class="font-display text-sm font-bold uppercase tracking-[0.16em] text-white/55">Beneficios</h4>
                    <ul class="mt-4 space-y-3 text-sm leading-7 text-white/62">
                      {service.benefits.slice(0, 2).map((benefit) => (
                        <li>• {benefit}</li>
                      ))}
                    </ul>
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>

      <div class="space-y-8">
        <h2 class="heading-section">Línea infraestructura, mantención y obras</h2>
        {infrastructureServices.map((service) => (
          <article id={service.slug} class="panel scroll-mt-28 p-8 lg:p-10">
            <div class="grid gap-8 lg:grid-cols-[0.8fr,1.2fr]">
              <div class="space-y-4">
                <span class="eyebrow">{service.title}</span>
                <h3 class="heading-card text-balance">{service.short}</h3>
                <p class="copy-sm">{service.description}</p>
                <img src={serviceVisualBySlug[service.slug]} alt={service.title} class="h-44 w-full rounded-xl object-cover" loading="lazy" />
                <a href="/contacto" class="cta-primary">Cotizar ejecución técnica</a>
              </div>
              <div class="grid gap-5 md:grid-cols-2">
                <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-5">
                  <h4 class="font-display text-sm font-bold uppercase tracking-[0.16em] text-white/55">Problemas que resuelve</h4>
                  <ul class="mt-4 space-y-3 text-sm leading-7 text-white/62">
                    {service.problems.slice(0, 2).map((problem) => (
                      <li>• {problem}</li>
                    ))}
                  </ul>
                </div>
                <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-5">
                  <h4 class="font-display text-sm font-bold uppercase tracking-[0.16em] text-white/55">Beneficios</h4>
                  <ul class="mt-4 space-y-3 text-sm leading-7 text-white/62">
                    {service.benefits.slice(0, 2).map((benefit) => (
                      <li>• {benefit}</li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>