---
import IndustryCard from '@/components/IndustryCard.astro';
import PageHero from '@/components/PageHero.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { industries } from '@/data/site';
---

<BaseLayout
  title="Soluciones para negocios | NETCOM Servicios Integrales SpA"
  description="Soluciones tecnológicas e instalaciones técnicas para retail, pymes, oficinas, bodegas, edificios y negocios con punto de venta."
>
  <PageHero
    badge="Soluciones para negocios"
    title="Respuesta técnica según la realidad operativa de cada tipo de cliente"
    description="No todos los negocios requieren lo mismo. Esta sección presenta cómo NETCOM aterriza sus servicios a contextos comerciales, operativos y de infraestructura distintos."
  />

  <section class="section-space">
    <div class="container-shell space-y-12">
      <SectionHeading
        badge="Segmentos atendidos"
        title="Desde locales con caja hasta edificios y operaciones con infraestructura crítica"
        description="Cada segmento recibe una propuesta técnica y comercial alineada a su contexto operativo, nivel de continuidad requerido y plan de crecimiento."
      />
      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
        {industries.map((industry) => (
          <IndustryCard title={industry.title} description={industry.description} />
        ))}
      </div>
    </div>
  </section>

  <section class="section-space pt-0">
    <div class="container-shell grid gap-6 lg:grid-cols-3">
      <article class="panel p-6">
        <h2 class="font-display text-2xl font-bold text-white">Retail</h2>
        <p class="mt-3 text-sm leading-7 text-white/62">POS, inventario, soporte de caja, conectividad y CCTV para mantener la operación diaria con control y velocidad.</p>
      </article>
      <article class="panel p-6">
        <h2 class="font-display text-2xl font-bold text-white">Oficinas y pymes</h2>
        <p class="mt-3 text-sm leading-7 text-white/62">Redes ordenadas, soporte TI, seguridad y habilitación técnica para ambientes de trabajo profesionales y confiables.</p>
      </article>
      <article class="panel p-6">
        <h2 class="font-display text-2xl font-bold text-white">Bodegas y edificios</h2>
        <p class="mt-3 text-sm leading-7 text-white/62">Cobertura de red, control de acceso, cámaras y canalización para espacios de alta circulación y control operativo.</p>
      </article>
    </div>
  </section>
</BaseLayout>